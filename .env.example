# BioScout Environment Variables
# Copy this file to .env and fill in your values

# DeepSeek API (get key at https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Django
SECRET_KEY=django-insecure-change-this-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for dev, PostgreSQL URL for production)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Base URL for building image URLs (no trailing slash)
BASE_URL=http://127.0.0.1:8000
